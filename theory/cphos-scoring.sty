\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cphos-scoring}[2026/03/09 v1.4 CPHOS Scoring System (Fixed Undefined Control Sequence)]

\RequirePackage{xparse}
\RequirePackage{xcolor}

\ExplSyntaxOn

\cs_generate_variant:Nn \regex_match:nnTF { nV }

% ============================================
% 存储结构
% ============================================
\seq_new:N \g__cphos_entries_seq

% ============================================
% 分值检查开关与存储
% ============================================
\bool_new:N \g__cphos_check_score_bool
\bool_gset_false:N \g__cphos_check_score_bool

\NewDocumentCommand{\setscorecheck}{m}{
    \str_if_eq:nnTF {#1} {true} {
        \bool_gset_true:N \g__cphos_check_score_bool
    }{
        \bool_gset_false:N \g__cphos_check_score_bool
    }
}

\tl_new:N \g__cphos_problem_score_tl
\tl_gset:Nn \g__cphos_problem_score_tl {}

\NewDocumentCommand{\setproblemscore}{m}{
    \tl_gset:Nn \g__cphos_problem_score_tl {#1}
}

% ============================================
% 内部函数
% ============================================
\cs_new:Npn \__cphos_clear: {
    \seq_gclear:N \g__cphos_entries_seq
}

\cs_new:Npn \__cphos_add:nnnn #1 #2 #3 #4 {
    \seq_gput_right:Nn \g__cphos_entries_seq {{#1}{#2}{#3}{#4}}
}

% ============================================
% 用户接口
% ============================================
\NewDocumentCommand{\clearScores}{}{ \__cphos_clear: }

\NewDocumentCommand{\scorePart}{m m}{ \__cphos_add:nnnn {0}{#1}{#2}{part} }
\NewDocumentCommand{\scorepart}{m m}{ \__cphos_add:nnnn {1}{#1}{#2}{q1} }
\NewDocumentCommand{\scoresubpart}{m m}{ \__cphos_add:nnnn {2}{#1}{#2}{q2} }
\NewDocumentCommand{\scoresubsubpart}{m m}{ \__cphos_add:nnnn {3}{#1}{#2}{q3} }

\NewDocumentCommand{\scorePartalt}{m m}{ \__cphos_add:nnnn {0}{#1}{#2}{part_alt} }
\NewDocumentCommand{\scorepartalt}{m m}{ \__cphos_add:nnnn {1}{#1}{#2}{q1_alt} }
\NewDocumentCommand{\scoresubpartalt}{m m}{ \__cphos_add:nnnn {2}{#1}{#2}{q2_alt} }
\NewDocumentCommand{\scoresubsubpartalt}{m m}{ \__cphos_add:nnnn {3}{#1}{#2}{q3_alt} }

\NewDocumentCommand{\eqtag}{m}{ \tag*{(#1)} }
\NewDocumentCommand{\eqtagscore}{m m}{ \tag*{(#1)} \__cphos_add:nnnn {4}{#1}{#2}{eq} }
\NewDocumentCommand{\addeqscore}{m m}{ \__cphos_add:nnnn {4}{#1}{#2}{eq} }
\NewDocumentCommand{\addtextscore}{m m}{ \__cphos_add:nnnn {4}{#1}{#2}{text} }

\cs_new:Npn \__cphos_kv_ignore:n #1 {}
\cs_new:Npn \__cphos_kv_add:nn #1 #2 { \__cphos_add:nnnn {4}{#1}{#2}{eq} }
\NewDocumentCommand{\seteqscores}{m}{ \keyval_parse:NNn \__cphos_kv_ignore:n \__cphos_kv_add:nn {#1} }

% ============================================
% 核心处理逻辑 
% ============================================
\tl_new:N \l__cphos_output_tl
\prop_new:N \l__cphos_eq_by_score_prop
\seq_new:N \l__cphos_score_values_seq
\tl_new:N \l__cphos_text_items_tl
\int_new:N \l__cphos_eq_count_int

\seq_new:N \g__cphos_stack_level_seq
\seq_new:N \g__cphos_stack_label_seq
\seq_new:N \g__cphos_stack_declared_seq
\seq_new:N \g__cphos_stack_actual_seq
\seq_new:N \g__cphos_stack_type_seq
\seq_new:N \g__cphos_warnings_seq
\int_new:N \g__cphos_actual_total_int

\cs_new:Npn \__cphos_add_eq:nn #1 #2 {
    \prop_if_in:NnTF \l__cphos_eq_by_score_prop {#2} {
        \prop_get:NnN \l__cphos_eq_by_score_prop {#2} \l_tmpa_tl
        \tl_put_right:Nn \l_tmpa_tl {（#1）}
        \prop_gput:NnV \l__cphos_eq_by_score_prop {#2} \l_tmpa_tl
    }{
        \prop_gput:Nnn \l__cphos_eq_by_score_prop {#2} {（#1）}
        \seq_gput_right:Nn \l__cphos_score_values_seq {#2}
    }
    \seq_if_empty:NF \g__cphos_stack_actual_seq {
        \seq_gpop_right:NN \g__cphos_stack_actual_seq \l_tmpa_tl
        \seq_gput_right:Nx \g__cphos_stack_actual_seq { \int_eval:n { \l_tmpa_tl + #2 } }
    }
}

\cs_new:Npn \__cphos_flush_items: {
    \seq_sort:Nn \l__cphos_score_values_seq { \int_compare:nNnTF {##1} > {##2} { \sort_return_swapped: } { \sort_return_same: } }
    \seq_map_inline:Nn \l__cphos_score_values_seq {
        \prop_get:NnN \l__cphos_eq_by_score_prop {##1} \l_tmpa_tl
        \int_zero:N \l__cphos_eq_count_int
        \tl_map_inline:Nn \l_tmpa_tl { \token_if_eq_charcode:NNT ####1 （ { \int_incr:N \l__cphos_eq_count_int } }
        \tl_put_right:NV \l__cphos_output_tl \l_tmpa_tl
        \int_compare:nNnTF {\l__cphos_eq_count_int} > {1} 
            { \tl_put_right:Nn \l__cphos_output_tl { 式各 ##1 分， } }
            { \tl_put_right:Nn \l__cphos_output_tl { 式 ##1 分， } }
    }
    \tl_if_empty:NF \l__cphos_text_items_tl { \tl_put_right:NV \l__cphos_output_tl \l__cphos_text_items_tl }
    \prop_gclear:N \l__cphos_eq_by_score_prop
    \seq_gclear:N \l__cphos_score_values_seq
    \tl_clear:N \l__cphos_text_items_tl
}

\cs_new:Npn \__cphos_replace_last_comma:Nn #1 #2 {
    \tl_if_empty:NF #1 { \regex_replace_once:nnN { ， \Z } { #2 } #1 }
}

\cs_new:Npn \__cphos_pop_and_check: {
    \seq_if_empty:NT \g__cphos_stack_level_seq { \prev_return } 
    \seq_gpop_right:NN \g__cphos_stack_level_seq \l_tmp_level_tl
    \seq_gpop_right:NN \g__cphos_stack_label_seq \l_tmp_label_tl
    \seq_gpop_right:NN \g__cphos_stack_declared_seq \l_tmp_declared_tl
    \seq_gpop_right:NN \g__cphos_stack_actual_seq \l_tmp_actual_tl
    \seq_gpop_right:NN \g__cphos_stack_type_seq \l_tmp_type_tl

    \bool_if:NT \g__cphos_check_score_bool {
        \int_compare:nNnF { \l_tmp_declared_tl } = { \l_tmp_actual_tl } {
            \tl_clear:N \l_tmpb_tl
            \str_if_in:NnT \l_tmp_type_tl { alt } { \tl_set:Nn \l_tmpb_tl { 【另解】 } }
            \int_case:nn { \l_tmp_level_tl } {
                {0} { \tl_put_right:Nn \l_tmpb_tl { Part~ } \tl_put_right:NV \l_tmpb_tl \l_tmp_label_tl }
                {1} { \tl_put_right:Nn \l_tmpb_tl { 第（ } \tl_put_right:NV \l_tmpb_tl \l_tmp_label_tl \tl_put_right:Nn \l_tmpb_tl { ）问 } }
                {2} { \tl_put_right:Nn \l_tmpb_tl { 第（ } \tl_put_right:NV \l_tmpb_tl \l_tmp_label_tl \tl_put_right:Nn \l_tmpb_tl { ）问 } }
                {3} { \tl_put_right:Nn \l_tmpb_tl { 第（ } \tl_put_right:NV \l_tmpb_tl \l_tmp_label_tl \tl_put_right:Nn \l_tmpb_tl { ）问 } }
            }
            \tl_put_right:Nx \l_tmpb_tl { ：声明 \l_tmp_declared_tl 分，实际 \l_tmp_actual_tl 分 }
            \seq_gput_right:NV \g__cphos_warnings_seq \l_tmpb_tl
        }
    }

    \str_if_in:NnF \l_tmp_type_tl { alt } {
        \seq_if_empty:NTF \g__cphos_stack_actual_seq {
            \int_gadd:Nn \g__cphos_actual_total_int { \l_tmp_declared_tl }
        }{
            \seq_gpop_right:NN \g__cphos_stack_actual_seq \l_tmpa_tl
            \seq_gput_right:Nx \g__cphos_stack_actual_seq { \int_eval:n { \l_tmpa_tl + \l_tmp_declared_tl } }
        }
    }
}

% 递归弹栈
\cs_new:Npn \__cphos_pop_until:n #1 {
    \seq_if_empty:NF \g__cphos_stack_level_seq {
        \seq_get_right:NN \g__cphos_stack_level_seq \l_tmpa_tl
        \int_compare:nNnF { \l_tmpa_tl } < {#1} { 
            \__cphos_pop_and_check: 
            \__cphos_pop_until:n {#1} 
        }
    }
}

% 递归清空所有剩余栈（代替了报错的那个 non-existent loop）
\cs_new:Npn \__cphos_pop_all: {
    \seq_if_empty:NF \g__cphos_stack_level_seq {
        \__cphos_pop_and_check:
        \__cphos_pop_all:
    }
}

\cs_new:Npn \__cphos_process:nnnn #1 #2 #3 #4 {
    \int_compare:nNnTF {#1} = {4} {
        \str_if_eq:nnTF {#4} {eq} { \__cphos_add_eq:nn {#2} {#3} }{
            \tl_put_right:Nn \l__cphos_text_items_tl {#2#3分，}
            \seq_if_empty:NF \g__cphos_stack_actual_seq {
                \seq_gpop_right:NN \g__cphos_stack_actual_seq \l_tmpa_tl
                \seq_gput_right:Nx \g__cphos_stack_actual_seq { \int_eval:n { \l_tmpa_tl + #3 } }
            }
        }
    }{
        \__cphos_flush_items:
        \__cphos_replace_last_comma:Nn \l__cphos_output_tl {；}
        \__cphos_pop_until:n {#1}
        \seq_gput_right:Nn \g__cphos_stack_level_seq {#1}
        \seq_gput_right:Nn \g__cphos_stack_label_seq {#2}
        \seq_gput_right:Nn \g__cphos_stack_declared_seq {#3}
        \seq_gput_right:Nn \g__cphos_stack_actual_seq {0}
        \seq_gput_right:Nn \g__cphos_stack_type_seq {#4}
        
        \str_if_in:nnTF {#4} { alt } 
            { \tl_put_right:Nn \l__cphos_output_tl { \par\noindent \textbf{另解}： } }
            { \tl_put_right:Nn \l__cphos_output_tl { \par } }
            
        \int_case:nn {#1} {
            {0}{ \tl_put_right:Nn \l__cphos_output_tl { Part~#2~#3分：} }
            {1}{ \tl_put_right:Nn \l__cphos_output_tl { 第（#2）问#3分：} }
            {2}{ \tl_put_right:Nn \l__cphos_output_tl { 第（#2）问#3分：} }
            {3}{ \tl_put_right:Nn \l__cphos_output_tl { 第（#2）问#3分：} }
        }
    }
}

\cs_new:Npn \__cphos_generate: {
    \tl_clear:N \l__cphos_output_tl \prop_gclear:N \l__cphos_eq_by_score_prop
    \seq_gclear:N \l__cphos_score_values_seq \tl_clear:N \l__cphos_text_items_tl
    \seq_gclear:N \g__cphos_warnings_seq \int_gzero:N \g__cphos_actual_total_int
    \seq_gclear:N \g__cphos_stack_level_seq \seq_get_right:NN \g__cphos_stack_level_seq \l_tmpa_tl % 清空
    \seq_gclear:N \g__cphos_stack_label_seq \seq_gclear:N \g__cphos_stack_declared_seq 
    \seq_gclear:N \g__cphos_stack_actual_seq \seq_gclear:N \g__cphos_stack_type_seq
    
    \seq_map_inline:Nn \g__cphos_entries_seq { \__cphos_process:nnnn ##1 }
    \__cphos_flush_items:
    
    \__cphos_pop_all: % 这里原本写了会报错的 \seq_until_do:nn，现在用自写递归函数替代，安全了。
    
    \__cphos_replace_last_comma:Nn \l__cphos_output_tl {。}
    
    \par\noindent\bfseries 评分标准：\tl_if_empty:NF \g__cphos_problem_score_tl { 本题满分\g__cphos_problem_score_tl 分。}
    \l__cphos_output_tl \mdseries
    \bool_if:NT \g__cphos_check_score_bool {
        \tl_if_empty:NF \g__cphos_problem_score_tl {
            \int_compare:nNnF { \g__cphos_actual_total_int } = { \g__cphos_problem_score_tl } {
                \seq_gput_right:Nx \g__cphos_warnings_seq { 题目总分声明~\g__cphos_problem_score_tl~分，主解法合计~\int_use:N \g__cphos_actual_total_int~分 }
            }
        }
        \seq_if_empty:NF \g__cphos_warnings_seq {
            \par\noindent\textcolor{red}{\bfseries 【分值检查警告】}
            \seq_map_inline:Nn \g__cphos_warnings_seq { \par\noindent\textcolor{red}{##1} }
        }
    }
}

\NewDocumentCommand{\scoring}{}{ \par\vspace{0.5\baselineskip} \__cphos_generate: \par\vspace{0.5\baselineskip} }

\ExplSyntaxOff
\endinput
